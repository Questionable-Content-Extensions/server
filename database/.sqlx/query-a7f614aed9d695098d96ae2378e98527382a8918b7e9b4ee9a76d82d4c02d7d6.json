{
  "db_name": "MySQL",
  "query": "\n                SELECT\n                    `i`.`id`,\n                    `i`.`short_name`,\n                    `i`.`name`,\n                    `i`.`type`,\n                    `i`.`color_blue`,\n                    `i`.`color_green`,\n                    `i`.`color_red`,\n                    `i`.`primary_image`,\n                    COUNT(`o`.`comic_id`) AS `count`\n                FROM `Item` `i`\n                LEFT JOIN `Occurrence` `o` ON `o`.`item_id` = `i`.`id`\n                GROUP BY `i`.`id`\n                ORDER BY `count` DESC\n            ",
