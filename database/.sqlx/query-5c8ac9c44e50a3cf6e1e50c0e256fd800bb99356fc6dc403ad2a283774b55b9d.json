{
  "db_name": "MySQL",
  "query": "\n                SELECT\n                    `i`.`id`,\n                    `i`.`short_name`,\n                    `i`.`name`,\n                    `i`.`type`,\n                    `i`.`color_blue`,\n                    `i`.`color_green`,\n                    `i`.`color_red`,\n                    `i`.`primary_image`,\n                    `i`.`start_comic_id`,\n                    `i`.`end_comic_id`,\n                    occ.first AS `first: u16`,\n                    occ.last AS `last: u16`,\n                    occ.count,\n                    comics.total_comics,\n                    imgs.image_count,\n                    imgs.first_image_id AS `first_image_id: u32`\n                FROM `Item` `i`\n                CROSS JOIN (\n                    SELECT\n                        MIN(`comic_id`) AS first,\n                        MAX(`comic_id`) AS last,\n                        COUNT(`comic_id`) AS `count`\n                    FROM `Occurrence`\n                    WHERE `item_id` = ?\n                ) AS occ\n                CROSS JOIN (SELECT COUNT(*) AS total_comics FROM `Comic`) AS comics\n                CROSS JOIN (\n                    SELECT COUNT(*) AS image_count, MIN(`id`) AS first_image_id\n                    FROM `ItemImage`\n                    WHERE `item_id` = ?\n                ) AS imgs\n                WHERE `i`.`id` = ?\n            ",
